"[apple]\n"
"team_id = \"ABCDE12345\"\n"
"key_id = \"KEYID123\"\n"
"issuer_id = \"issuer-uuid-here\"\n"
"p8_key_path = \"/Users/me/.perry/AuthKey.p8\"\n"
"\n"
"[android]\n"
"keystore_path = \"/Users/me/.perry/release.keystore\"\n"
"key_alias = \"my-key\"\n"
"google_play_key_path = \"/Users/me/.perry/play-service-account.json\"\n"
