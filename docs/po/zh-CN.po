"```typescript\n"
"// Raw is a pass-through — prevents auto-formatting when the param name\n"
"// might otherwise trigger it.\n"
"const orderCode = Raw(12345)\n"
"console.log(t(\"Code: {amount}\", { amount: orderCode }))\n"
