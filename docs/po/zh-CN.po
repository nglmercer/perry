msgstr "1"

#: src/ui/layout.md:224
msgid "FillEqually"
msgstr "FillEqually"

#: src/ui/layout.md:224
msgid "All children get equal size"
msgstr "所有子项获得相等尺寸"

#: src/ui/layout.md:225 src/platforms/windows-7.md:26
#: src/testing/geisterhand.md:88 src/testing/geisterhand.md:102
#: src/cli/perry-toml.md:403
