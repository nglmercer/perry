"        ForEach(entry.items, (item) => Text(item.name)),\n"
"      ])\n"
"    : HStack([\n"
"        Image(\"star.fill\"),\n"
"        Text(entry.title).font(\"headline\"),\n"
"      ]),\n"
"```"
msgstr ""

