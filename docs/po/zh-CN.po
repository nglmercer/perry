" */\n"
"export function parse(buf: Uint8Array): string {\n"
"  // Unreachable under perry — links to js_pdf_parse instead.\n"
"  throw new Error(\"Not implemented under V8 fallback\");\n"
"}\n"
"```"
msgstr ""

