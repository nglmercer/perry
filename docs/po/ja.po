msgstr "シングルトンパターン(静的メソッドの戻り値型推論)"

#: src/language/supported-features.md:104
msgid "Enums"
msgstr "列挙型"

#: src/language/supported-features.md:106
msgid ""
"```typescript\n"
"// Numeric enums\n"
"enum Direction {\n"
"    Up,\n"
"    Down,\n"
"    Left,\n"
"    Right,\n"
"}\n"
"\n"
"// String enums\n"
