"alpha\n"
"backgroundColor: \"blue\"                                      // named "
"color\n"
"backgroundColor: { r: 0.231, g: 0.510, b: 0.965, a: 1.0 }   // PerryColor "
"object\n"
"backgroundColor: themeColor                                  // runtime "
"variable\n"
