"\n"
"    const user = { name: \"Alice\", age: 30, email: \"a@example.com\", id: "
"1 }\n"
"    const obj = { id: 2, role: \"admin\", level: 5 }\n"
"\n"
"    // Object destructuring\n"
"    const { name, age, email = \"none\" } = user;\n"
"\n"
"    // Rename\n"
