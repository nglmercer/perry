"            Text(\"Header\"),\n"
"            HStack(8, [\n"
"                Button(\"Left\", () => console.log(\"left\")),\n"
"                Button(\"Right\", () => console.log(\"right\")),\n"
"            ]),\n"
"            Text(\"Footer\"),\n"
"        ]),\n"
"    })\n"
"}\n"
