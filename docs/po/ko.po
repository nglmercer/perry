msgstr "포인트 단위의 둥근 모서리"

#: src/ui/widgets.md:624
msgid "`widgetSetOpacity(w, alpha)`"
msgstr ""

#: src/ui/widgets.md:624
msgid "Opacity in \\[0, 1\\]"
msgstr "\\[0, 1\\]의 불투명도"

#: src/ui/widgets.md:625
msgid "`widgetSetEnabled(w, flag)`"
msgstr ""

#: src/ui/widgets.md:625
