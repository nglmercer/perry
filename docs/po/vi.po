"    widgetSetEdgeInsets,\n"
"    widgetSetWidth, widgetSetHeight, widgetMatchParentWidth,\n"
"    widgetSetOpacity,\n"
"    widgetSetControlSize,\n"
"    widgetSetTooltip,\n"
"    widgetSetEnabled,\n"
"} from \"perry/ui\"\n"
