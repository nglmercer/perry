msgstr "Fetch API"

#: src/stdlib/http.md:236
msgid ""
"```typescript\n"
"async function fetchExamples(): Promise<void> {\n"
"    // GET request\n"
"    const response = await fetch(\"https://jsonplaceholder.typicode.com/"
