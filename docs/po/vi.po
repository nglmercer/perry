"menuAddItem(ctx, \"Paste\",  () => status.set(\"ctx/paste\"))\n"
"menuAddSeparator(ctx)\n"
"menuAddItem(ctx, \"Delete\", () => status.set(\"ctx/delete\"))\n"
"widgetSetContextMenu(label, ctx)\n"
"```"
