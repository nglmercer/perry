#: src/language/supported-features.md:104
msgid "Enums"
msgstr "Enum"

#: src/language/supported-features.md:106
msgid ""
"```typescript\n"
"// Numeric enums\n"
"enum Direction {\n"
"    Up,\n"
"    Down,\n"
"    Left,\n"
"    Right,\n"
"}\n"
"\n"
"// String enums\n"
